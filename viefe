var gapsExpanded = {};
var invGapsExpanded = {};

function computeCatalogGaps(){
  var invSkus = {};
  ALL_INVENTORY.forEach(function(d){ invSkus[d.sku] = true; });

  var catalogTotalByFam = {};
  Object.keys(PRICE_CATALOG).forEach(function(sku){
    var f = PRICE_CATALOG[sku].family;
    catalogTotalByFam[f] = (catalogTotalByFam[f] || 0) + 1;
  });

  var haveByFam = {};
  ALL_INVENTORY.forEach(function(d){
    if(!PRICE_CATALOG[d.sku]) return;
    var f = PRICE_CATALOG[d.sku].family;
    haveByFam[f] = (haveByFam[f] || 0) + 1;
  });

  var groups = {};
  var order = [];
  Object.keys(PRICE_CATALOG).forEach(function(sku){
    if(invSkus[sku]) return;
    var cat = PRICE_CATALOG[sku];
    var f = cat.family;
    if(!groups[f]){ groups[f] = []; order.push(f); }
    groups[f].push({
      sku: sku, finishCode: cat.finishCode, finishName: cat.finishName,
      size: cat.size, pu: cat.pu, pe: cat.pe
    });
  });

  order.forEach(function(f){
    groups[f].sort(function(a, b){
      var sa = parseInt(a.size, 10); if(isNaN(sa)) sa = 0;
      var sb = parseInt(b.size, 10); if(isNaN(sb)) sb = 0;
      return sa - sb;
    });
  });

  var out = order.map(function(f){
    var total = catalogTotalByFam[f] || groups[f].length;
    var have = haveByFam[f] || 0;
    return { family: f, items: groups[f], total: total, have: have, pctComplete: total>0 ? Math.round(have/total*100) : 0 };
  });
  out.sort(function(a, b){ return a.pctComplete - b.pctComplete; });
  return out;
}

function computeInventoryGaps(){
  var groups = {};
  var order = [];
  ALL_INVENTORY.forEach(function(inv){
    if(PRICE_CATALOG[inv.sku]) return;
    var f = naiveFamily(inv.desc);
    if(!groups[f]){ groups[f] = []; order.push(f); }
    groups[f].push(inv);
  });
  order.forEach(function(f){
    groups[f].sort(function(a, b){ return a.sku.localeCompare(b.sku); });
  });
  var out = order.map(function(f){ return {family: f, items: groups[f]}; });
  out.sort(function(a, b){ return b.items.length - a.items.length; });
  return out;
}


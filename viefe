function activateData(rows, sourceLabel, dateLabel){
  DATA = buildDataFromInventoryRows(rows);
  ALL_INVENTORY = buildAllViefeInventory(rows);
  RAW_VIEFE_ROWS = rows.filter(function(row){
    var vendorCode = String(row['Vendor Code'] || '').trim();
    var vendorName = String(row['Vendor Name'] || '').toUpperCase();
    return vendorCode === '18' || vendorName.indexOf('VIEFE') !== -1;
  });
  if(DATA.length === 0){
    setStatus('err', 'El reporte no contiene SKUs activos de VIEFE (Vendor 18). Verifica el archivo.');
    return;
  }
  recomputeFamilyCodes();
  document.getElementById('mainWrap').classList.remove('hidden');
  document.getElementById('uploadPanel').classList.remove('show');
  setStatus('ok', sourceLabel + ' \u00b7 ' + DATA.length + ' SKUs activos VIEFE (' + ALL_INVENTORY.length + ' en total en Epicor)' + (dateLabel ? ' \u00b7 ' + dateLabel : ''));
  populateFilterOptions();
  render();
}

function tryLoadFromHub(){
  setStatus('loading', 'Buscando reporte de inventario del hub...');
  var raw;
  try{ raw = sessionStorage.getItem('CCP_REPORT'); } catch(e){ raw = null; }
  if(!raw){
    setStatus('err', 'No se encontro el reporte en el hub. Cargalo manualmente abajo.');
    document.getElementById('uploadPanel').classList.add('show');
    return;
  }
  try{
    var rows = JSON.parse(raw);
    var dateRaw = null;
    try{ dateRaw = sessionStorage.getItem('CCP_REPORT_DATE'); } catch(e){}
    var dateLabel = '';
    if(dateRaw){
      var d = new Date(dateRaw);
      dateLabel = 'reporte del ' + d.toLocaleDateString('es-PR', {day:'2-digit', month:'short', year:'numeric'});
    }
    activateData(rows, 'Cargado del hub', dateLabel);
  } catch(e){
    setStatus('err', 'Error leyendo el reporte del hub: ' + e.message);
    document.getElementById('uploadPanel').classList.add('show');
  }
}

function parseSheetRows(workbook){
  var ws = workbook.Sheets[workbook.SheetNames[0]];
  return XLSX.utils.sheet_to_json(ws, {defval: ''});
}

function handleFileUpload(file){
  document.getElementById('fileStatus').textContent = 'Leyendo ' + file.name + '...';
  var reader = new FileReader();
  reader.onload = function(e){
    try{
      var wb = XLSX.read(e.target.result, {type: 'array', cellDates: true});
      var rows = parseSheetRows(wb);
      activateData(rows, 'Archivo cargado manualmente (' + file.name + ')', '');
      document.getElementById('fileStatus').textContent = '';
    } catch(err1){
      var reader2 = new FileReader();
      reader2.onload = function(e2){
        try{
          var wb2 = XLSX.read(e2.target.result, {type: 'binary', cellDates: true});
          var rows2 = parseSheetRows(wb2);
          activateData(rows2, 'Archivo cargado manualmente (' + file.name + ')', '');
          document.getElementById('fileStatus').textContent = '';
        } catch(err2){
          document.getElementById('fileStatus').textContent = 'No se pudo leer el archivo: ' + err2.message;
        }
      };
      reader2.readAsBinaryString(file);
    }
  };
  reader.readAsArrayBuffer(file);
}


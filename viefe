function groupByFamily(rows){
  var groups = {};
  var order = [];
  rows.forEach(function(r){
    var f = r.d.family;
    if(!groups[f]){ groups[f] = []; order.push(f); }
    groups[f].push(r);
  });

  order.forEach(function(f){
    groups[f].sort(function(a, b){
      var sa = parseInt(a.d.size, 10); if(isNaN(sa)) sa = 0;
      var sb = parseInt(b.d.size, 10); if(isNaN(sb)) sb = 0;
      if(sa !== sb) return sa - sb;
      return a.d.finishName.localeCompare(b.d.finishName);
    });
  });

  var groupObjs = order.map(function(f){
    var rws = groups[f];
    var totalL12 = rws.reduce(function(s, r){ return s + r.d.l12; }, 0);
    var totalLine = rws.reduce(function(s, r){ return s + (r.hasPrice ? r.lineTotal : 0); }, 0);
    return {family: f, rows: rws, totalL12: totalL12, totalLine: totalLine};
  });

  if(state.familySort === 'alpha'){
    groupObjs.sort(function(a, b){ return a.family.localeCompare(b.family); });
  } else if(state.familySort === 'total'){
    groupObjs.sort(function(a, b){ return b.totalLine - a.totalLine; });
  } else {
    groupObjs.sort(function(a, b){ return b.totalL12 - a.totalL12; });
  }
  return groupObjs;
}

function familyMosaic(rows, familyName){
  var seen = {}; var items = [];
  rows.forEach(function(r){
    if(!seen[r.d.finishCode]){ seen[r.d.finishCode] = true; items.push({code: r.d.finishCode, name: r.d.finishName}); }
  });
  items = items.slice(0, 6);
  return items.map(function(it){
    return '<button type="button" class="chip-btn mosaic-chip" data-family="' + familyName + '" data-color="' + it.name + '" title="' + it.name + ' (toca para filtrar)">' +
      '<img class="swatch" src="' + finishImg(it.code) + '" alt="' + it.name + '" onerror="this.style.visibility=\'hidden\'"></button>';
  }).join('');
}


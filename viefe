  Array.prototype.forEach.call(list.querySelectorAll('.mosaic-chip'), function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      var fam = btn.getAttribute('data-family');
      var color = btn.getAttribute('data-color');

function naiveFamily(desc){
  var toks = String(desc || '').trim().split(/\s+/);
  return toks[0] ? toks[0].toUpperCase() : 'OTHER';
}

function num(v){
  var n = parseFloat(v);
  return isNaN(n) ? 0 : n;
}

function buildDataFromInventoryRows(rows){
  var out = [];
  rows.forEach(function(row){
    var vendorCode = String(row['Vendor Code'] || '').trim();
    var vendorName = String(row['Vendor Name'] || '').toUpperCase();
    if(vendorCode !== '18' && vendorName.indexOf('VIEFE') === -1) return;

    var sku = String(row['Item Number'] || '').trim();
    if(!/^[0-9]/.test(sku)) return;

    var l12 = num(row['Last 12 Months Sales']);
    if(l12 <= 0) return;

    var cat = PRICE_CATALOG[sku];
    var desc = String(row['Item Description'] || '').trim();

    out.push({
      sku: sku,
      desc: desc,
      family: cat ? cat.family : naiveFamily(desc),
      familyCode: cat ? cat.familyCode : null,
      finishCode: cat ? cat.finishCode : '',
      finishName: cat ? cat.finishName : '',
      size: cat ? cat.size : '',
      qoh: num(row['Quantity on Hand']),
      qoo: num(row['Quantity on Order']),
      l12: l12,
      p3m: num(row['PROMEDI ULTIMO 3 MESES']),
      box: cat ? cat.box : 1,
      pkgWarn: cat ? cat.pkgWarn : true,
      pu: cat ? cat.pu : null,
      pe: cat ? cat.pe : null,
      disc: String(row['Discontinued Item?'] || '').trim().toUpperCase() === 'Y'
    });
  });
  return out;
}

function buildAllViefeInventory(rows){
  var out = [];
  rows.forEach(function(row){
    var vendorCode = String(row['Vendor Code'] || '').trim();
    var vendorName = String(row['Vendor Name'] || '').toUpperCase();
    if(vendorCode !== '18' && vendorName.indexOf('VIEFE') === -1) return;
    var sku = String(row['Item Number'] || '').trim();
    if(!sku) return;
    out.push({
      sku: sku,
      desc: String(row['Item Description'] || '').trim(),
      disc: String(row['Discontinued Item?'] || '').trim().toUpperCase() === 'Y',
      l12: num(row['Last 12 Months Sales'])
    });
  });
  return out;
}


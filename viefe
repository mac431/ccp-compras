function suggestPoNumber(){
  var now = new Date();
  var mm = String(now.getMonth() + 1).padStart(2, '0');
  var yyyy = now.getFullYear();
  return 'VIEFE' + mm + yyyy + '-01';
}
document.getElementById('poNumber').value = suggestPoNumber();

function buildPoText(){
  var rows = state._lastRows ? state._lastRows.filter(function(r){ return r.qty > 0; }) : [];
  var now = new Date();
  var dateLabel = now.toLocaleDateString('es-PR', {day:'2-digit', month:'long', year:'numeric'});
  var poNum = document.getElementById('poNumber').value || suggestPoNumber();
  var contact = document.getElementById('poContact').value || '(sin especificar)';
  var tariffLabel = state.tariff === 'US' ? 'US / Canada (USD)' : 'Espana (EUR)';

  var lines = [];
  lines.push('==========================================================');
  lines.push('ORDEN DE COMPRA - CARIBBEAN CABINET PRODUCTS');
  lines.push('Suplidor: VIEFE');
  lines.push('==========================================================');
  lines.push('PO Numero: ' + poNum);
  lines.push('Fecha: ' + dateLabel);
  lines.push('Atencion a: ' + contact);
  lines.push('Tarifa: ' + tariffLabel);
  lines.push('Meses de cobertura usados: ' + state.months);
  lines.push('----------------------------------------------------------');
  lines.push('');

  var groups = {};
  var order = [];
  rows.forEach(function(r){
    if(!groups[r.d.family]){ groups[r.d.family] = []; order.push(r.d.family); }
    groups[r.d.family].push(r);
  });
  order.sort();

  var grandTotal = 0;
  order.forEach(function(fam){
    lines.push(fam + ':');
    groups[fam].forEach(function(r){
      var priceTxt = r.hasPrice ? fmtMoney(r.unitPrice) : 'SIN PRECIO';
      var totalTxt = r.hasPrice ? fmtMoney(r.lineTotal) : '-';
      if(r.hasPrice) grandTotal += r.lineTotal;
      lines.push('  ' + r.d.sku.padEnd(16) + r.d.desc.padEnd(34) + '[' + r.d.finishName + ']'.padEnd(20) +
        'qty:' + String(r.qty).padStart(5) + '  (' + r.boxes + ' cj + ' + r.loose + ' suelt)  ' +
        priceTxt.padStart(10) + '  =  ' + totalTxt.padStart(10));
    });
    lines.push('');
  });

  lines.push('----------------------------------------------------------');
  lines.push('TOTAL FINAL: ' + (state._lastFinalTotal !== undefined ? fmtMoney(state._lastFinalTotal) : fmtMoney(grandTotal)));
  if(state.budgetEnabled){
    lines.push('Presupuesto maximo aplicado: ' + fmtMoney(state.budgetLimit));
    if(state._lastExcludedRows && state._lastExcludedRows.length){
      lines.push('');
      lines.push(state._lastExcludedRows.length + ' SKUs quedaron fuera de esta orden por presupuesto (pasan a la proxima):');
      state._lastExcludedRows.forEach(function(r){
        lines.push('  ' + r.d.sku + '  ' + r.d.desc + '  qty:' + r.qty + '  ' + (r.hasPrice ? fmtMoney(r.lineTotal) : 'sin precio'));
      });
    }
  }
  lines.push('==========================================================');
  return lines.join('\n');
}


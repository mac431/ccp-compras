      state.localFilter[fam].color = (state.localFilter[fam].color === color) ? '' : color;
      state.expanded[fam] = true;
      render();
    });
  });

  Array.prototype.forEach.call(list.querySelectorAll('.color-chip'), function(btn){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      var fam = btn.getAttribute('data-family');
      var color = btn.getAttribute('data-color');
      if(!state.localFilter[fam]) state.localFilter[fam] = {};
      state.localFilter[fam].color = (state.localFilter[fam].color === color) ? '' : color;
      render();
    });
  });

  Array.prototype.forEach.call(list.querySelectorAll('.size-chip'), function(btn){
    btn.addEventListener('click', function(e){

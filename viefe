function computeRow(d){
  var rate;
  if(state.rateMode === 'l12') rate = d.l12 / 12;
  else if(state.rateMode === 'p3m') rate = d.p3m;
  else rate = Math.max(d.l12 / 12, d.p3m);

  var suggested = Math.ceil(Math.max(0, rate * state.months - (d.qoh + d.qoo)) / d.box) * d.box;
  var qty = (state.qtyOverride[d.sku] !== undefined) ? state.qtyOverride[d.sku] : suggested;
  qty = Math.max(0, qty);

  var boxes = Math.floor(qty / d.box);
  var loose = qty - boxes * d.box;

  var unitPrice = (state.tariff === 'US') ? d.pu : d.pe;
  var hasPrice = unitPrice !== null && unitPrice !== undefined;

  var boxRate = (state.tariff === 'US') ? state.rules.usBox : state.rules.esBox;
  var looseRate = (state.tariff === 'US') ? state.rules.usLoose : state.rules.esLoose;

  var lineTotal = 0;
  if(hasPrice){
    lineTotal = boxes * d.box * unitPrice * (1 - boxRate / 100) + loose * unitPrice * (1 - looseRate / 100);
  }

  var coverage = (rate > 0) ? round2(d.qoh / rate) : (d.qoh > 0 ? 99 : 0);

  return {
    d: d, rate: round2(rate), suggested: suggested, qty: qty,
    boxes: boxes, loose: loose, unitPrice: unitPrice, hasPrice: hasPrice,
    lineTotal: round2(lineTotal), coverage: coverage
  };
}

function getFilteredRows(){
  var rows = DATA.map(computeRow);
  if(state.search){
    var s = state.search.toUpperCase();
    rows = rows.filter(function(r){
      return r.d.sku.toUpperCase().indexOf(s) !== -1 || r.d.desc.toUpperCase().indexOf(s) !== -1;
    });
  }
  if(state.family){ rows = rows.filter(function(r){ return r.d.family === state.family; }); }
  if(state.color){ rows = rows.filter(function(r){ return r.d.finishName === state.color; }); }
  if(state.size){ rows = rows.filter(function(r){ return r.d.size === state.size; }); }
  if(state.disc === 'active'){ rows = rows.filter(function(r){ return !r.d.disc; }); }
  if(state.disc === 'disc'){ rows = rows.filter(function(r){ return r.d.disc; }); }
  if(state.onlyOrder){ rows = rows.filter(function(r){ return r.qty > 0; }); }
  return rows;
}


function renderRisk(){
  var el = document.getElementById('riskList');
  if(!el) return;
  var limit = parseInt(document.getElementById('riskLimit').value, 10);
  var rows = DATA.map(computeRow).sort(function(a, b){ return a.coverage - b.coverage; });
  if(limit === 9999){
    rows = rows.filter(function(r){ return r.coverage < 3; });
  } else {
    rows = rows.slice(0, limit);
  }
  if(rows.length === 0){
    el.innerHTML = '<tr><td colspan="6" class="emptystate">Ningun SKU esta en riesgo critico ahora mismo.</td></tr>';
    return;
  }
  el.innerHTML = rows.map(function(r){
    var covClass = r.coverage < 1 ? 'cov-crit' : (r.coverage < 3 ? 'cov-warn' : 'cov-ok');
    return '<tr><td>' + r.d.sku + '</td><td>' + r.d.family + '</td><td>' + r.d.desc + '</td>' +
      '<td class="num">' + r.d.qoh + '</td><td class="num">' + r.rate + '</td>' +
      '<td class="num ' + covClass + '">' + (r.coverage >= 99 ? '99+' : r.coverage) + ' mes</td></tr>';
  }).join('');
}

function sortRowsByPriority(rows){
  var sorted = rows.slice();
  if(state.budgetPriority === 'risk'){
    sorted.sort(function(a,b){ return a.coverage - b.coverage; });
  } else if(state.budgetPriority === 'revenue'){
    sorted.sort(function(a,b){ return b.d.l12 - a.d.l12; });
  } else if(state.budgetPriority === 'family'){
    var famRank = {};
    DATA.forEach(function(d){ famRank[d.family] = (famRank[d.family]||0) + d.l12; });
    sorted.sort(function(a,b){
      var fa = famRank[a.d.family]||0, fb = famRank[b.d.family]||0;
      if(fb !== fa) return fb - fa;
      return a.coverage - b.coverage;
    });
  }
  return sorted;
}

function recomputeRowForQty(r, newQty){
  var box = r.d.box;
  var boxes = Math.floor(newQty / box);
  var loose = newQty - boxes * box;
  var boxRate = (state.tariff === 'US') ? state.rules.usBox : state.rules.esBox;
  var looseRate = (state.tariff === 'US') ? state.rules.usLoose : state.rules.esLoose;
  var lineTotal = 0;
  if(r.hasPrice){
    lineTotal = boxes * box * r.unitPrice * (1 - boxRate / 100) + loose * r.unitPrice * (1 - looseRate / 100);
  }
  var copy = {};
  for(var k in r){ copy[k] = r[k]; }
  copy.qty = newQty; copy.boxes = boxes; copy.loose = loose; copy.lineTotal = round2(lineTotal);
  copy.fullQty = r.fullQty !== undefined ? r.fullQty : r.qty;
  return copy;
}

function applyBudgetCutoff(rows){
  var withOrder = rows.filter(function(r){ return r.qty > 0; });
  if(!state.budgetEnabled || !state.budgetLimit || state.budgetLimit <= 0){
    return { included: withOrder, excluded: [], reduced: [] };
  }
  var sorted = sortRowsByPriority(withOrder);

  if(state.budgetMode === 'minimum'){
    var budget = state.budgetLimit;
    var allocated = {};
    sorted.forEach(function(r){
      var minQty = Math.min(r.d.box, r.qty);
      var rMin = recomputeRowForQty(r, minQty);
      var cost = rMin.hasPrice ? rMin.lineTotal : 0;
      if(cost <= budget){
        allocated[r.d.sku] = rMin;
        budget -= cost;
      } else {
        allocated[r.d.sku] = recomputeRowForQty(r, 0);
      }
    });
    sorted.forEach(function(r){
      var current = allocated[r.d.sku];
      if(current.qty >= r.qty) return;
      var box = r.d.box;
      var qty = current.qty;
      var safety = 0;
      while(qty < r.qty && safety < 1000){
        safety++;
        var nextQty = Math.min(qty + box, r.qty);
        var rNext = recomputeRowForQty(r, nextQty);
        var addCost = rNext.hasPrice ? (rNext.lineTotal - current.lineTotal) : 0;
        if(addCost <= budget){
          budget -= addCost;
          qty = nextQty;
          current = rNext;
        } else break;
      }
      allocated[r.d.sku] = current;
    });
    var included = [], excluded = [], reduced = [];
    sorted.forEach(function(r){
      var a = allocated[r.d.sku];
      if(a.qty <= 0){ excluded.push(r); }
      else {
        included.push(a);
        if(a.qty < r.qty) reduced.push(a);
      }
    });
    return { included: included, excluded: excluded, reduced: reduced };
  }

  var included = [], excluded = [];
  var spent = 0;
  sorted.forEach(function(r){
    var cost = r.hasPrice ? r.lineTotal : 0;
    if(spent + cost <= state.budgetLimit){
      included.push(r);
      spent += cost;
    } else {
      excluded.push(r);
    }
  });
  return { included: included, excluded: excluded, reduced: [] };
}

function renderSummary(allRows){
  var cutoff = applyBudgetCutoff(allRows);
  var rowsForTotals = cutoff.included;

  var totalPieces = 0, totalBoxes = 0, totalLoosePieces = 0, subtotalList = 0, subtotalNet = 0, skusWithOrder = 0;
  rowsForTotals.forEach(function(r){
    skusWithOrder++;
    totalPieces += r.qty;
    totalBoxes += r.boxes;
    totalLoosePieces += r.loose;
    if(r.hasPrice){
      subtotalList += r.qty * r.unitPrice;
      subtotalNet += r.lineTotal;
    }
  });

  var extraApplied = false;
  var finalTotal = subtotalNet;
  var thresholdNoteText = '';
  if(state.tariff === 'ES'){
    var base = (state.rules.thresholdBase === 'gross') ? subtotalList : subtotalNet;
    if(base > state.rules.esThreshold){
      extraApplied = true;
      finalTotal = subtotalNet * (1 - state.rules.esExtra / 100);
    }
    thresholdNoteText = 'Umbral Espana: ' + fmtMoney(state.rules.esThreshold) +
      ' (' + (state.rules.thresholdBase === 'gross' ? 'sobre total lista' : 'sobre total neto') + '). ' +
      (extraApplied ? ('Se aplico el ' + state.rules.esExtra + '% adicional.') : 'No se alcanzo el umbral para el descuento adicional.');
  }

  var grid = document.getElementById('summaryGrid');
  var items = [
    {lbl:'SKUs con orden', val: skusWithOrder},
    {lbl:'Piezas totales', val: totalPieces},
    {lbl:'Cajas completas', val: totalBoxes},
    {lbl:'Piezas sueltas', val: totalLoosePieces},
    {lbl:'Subtotal lista', val: fmtMoney(subtotalList)},
    {lbl:'Subtotal con descuento', val: fmtMoney(subtotalNet)},
    {lbl:'Total final', val: fmtMoney(finalTotal), total:true}
  ];
  grid.innerHTML = items.map(function(it){
    return '<div class="summary-item' + (it.total ? ' total' : '') + '"><div class="lbl">' + it.lbl + '</div><div class="val">' + it.val + '</div></div>';
  }).join('');

  document.getElementById('thresholdNote').textContent = thresholdNoteText;

  var budgetNoteText = '';
  if(state.budgetEnabled && (cutoff.excluded.length > 0 || cutoff.reduced.length > 0)){
    var excludedValue = cutoff.excluded.reduce(function(s,r){ return s + (r.hasPrice ? r.lineTotal : 0); }, 0);
    var parts = [];
    if(cutoff.reduced.length > 0){
      parts.push(cutoff.reduced.length + ' SKUs quedaron con cantidad REDUCIDA (menos de lo sugerido, pero no en cero) para poder cubrir un poco de todo');
    }
    if(cutoff.excluded.length > 0){
      parts.push(cutoff.excluded.length + ' SKUs (' + fmtMoney(excludedValue) + ' de haberse incluido completos) quedaron totalmente fuera de esta orden y pasan a la proxima');
    }
    budgetNoteText = 'Presupuesto de ' + fmtMoney(state.budgetLimit) + ' aplicado (' +
      (state.budgetMode === 'minimum' ? 'modo: minimo para todos + prioridad' : 'modo: prioridad completa') + '): ' +
      parts.join('; ') + '. Se priorizaron por: ' +
      (state.budgetPriority === 'risk' ? 'menor cobertura de stock primero' : state.budgetPriority === 'revenue' ? 'mayor venta (L12M) primero' : 'familias fuertes primero, luego riesgo') + '.';
  } else if(state.budgetEnabled){
    budgetNoteText = 'Presupuesto de ' + fmtMoney(state.budgetLimit) + ' aplicado: todos los SKUs sugeridos caben completos dentro del presupuesto.';
  }
  document.getElementById('budgetNote').textContent = budgetNoteText;

  state._lastRows = rowsForTotals;
  state._lastExcludedRows = cutoff.excluded;
  state._lastReducedRows = cutoff.reduced;
  state._lastFinalTotal = finalTotal;
}


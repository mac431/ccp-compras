function renderChart(){
  var canvas = document.getElementById('familyChart');
  var inner = document.getElementById('chartInner');
  if(!canvas || typeof Chart === 'undefined') return;

  var dimension = document.getElementById('chartDimension').value;
  var metric = document.getElementById('chartMetric').value;
  var sortMode = document.getElementById('chartSort').value;
  var topSel = document.getElementById('chartTop').value;
  var topN = (topSel === 'custom') ? (parseInt(document.getElementById('chartTopCustom').value, 10) || 20) : parseInt(topSel, 10);

  function keyOf(d){
    if(dimension === 'color') return d.finishName || '(sin color)';
    if(dimension === 'baseColor') return baseColorOf(d.finishName);
    if(dimension === 'size') return d.size ? (d.size + ' mm') : '(sin tamano)';
    return d.family;
  }

  var agg = {};
  DATA.forEach(function(d){
    var k = keyOf(d);
    if(!agg[k]) agg[k] = {l12: 0, revenue: 0};
    agg[k].l12 += d.l12;
    var price = (state.tariff === 'US') ? d.pu : d.pe;
    if(price) agg[k].revenue += d.l12 * price;
  });

  var list = Object.keys(agg).map(function(k){
    return {key: k, l12: agg[k].l12, revenue: Math.round(agg[k].revenue)};
  });

  if(sortMode === 'alpha'){
    list.sort(function(a, b){ return a.key.localeCompare(b.key); });
  } else {
    list.sort(function(a, b){
      return (metric === 'revenue') ? (b.revenue - a.revenue) : (b.l12 - a.l12);
    });
  }
  list = list.slice(0, topN);

  var labels = list.map(function(f){ return f.key; });
  var values = list.map(function(f){ return (metric === 'revenue') ? f.revenue : f.l12; });

  var barHeight = 26;
  var computedHeight = Math.max(420, labels.length * barHeight);
  inner.style.height = computedHeight + 'px';

  if(familyChartInstance){ familyChartInstance.destroy(); }
  familyChartInstance = new Chart(canvas.getContext('2d'), {
    type: 'bar',
    data: {
      labels: labels,
      datasets: [{
        label: (metric === 'revenue') ? 'Ingresos L12M (' + currencySymbol().trim() + ')' : 'Unidades vendidas L12M',
        data: values,
        backgroundColor: '#1b4d47'
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { beginAtZero: true },
        y: { ticks: { autoSkip: false, font: { size: 11 } } }
      }
    }
  });
}

var trendChartInstance = null;
var MONTH_ORDER = {JAN:1,FEB:2,MAR:3,APR:4,MAY:5,JUN:6,JUL:7,AUG:8,SEP:9,OCT:10,NOV:11,DEC:12};

function detectMonthColumns(){
  if(RAW_VIEFE_ROWS.length === 0) return [];
  var sample = RAW_VIEFE_ROWS[0];
  var cols = Object.keys(sample).filter(function(k){
    return /Sales Units\s*\n?[A-Z]{3}\s+\d{2}/.test(k);
  });
  var parsed = cols.map(function(k){
    var m = k.match(/([A-Z]{3})\s+(\d{2})/);
    return {key: k, mon: m[1], yr: parseInt(m[2], 10), sortVal: parseInt(m[2],10) * 100 + (MONTH_ORDER[m[1]] || 0)};
  });
  parsed.sort(function(a, b){ return a.sortVal - b.sortVal; });
  return parsed;
}


}

function combinedFamilyRows(haveRows, familyName){
  var missing = familyMissingCatalogItems(familyName);
  var lf = state.localFilter[familyName];
  if(lf){
    missing = missing.filter(function(m){
      if(lf.color && m.cat.finishName !== lf.color) return false;
      if(lf.size && m.cat.size !== lf.size) return false;
      return true;
    });
  }

  var items = [];
  haveRows.forEach(function(r){
    items.push({ size: r.d.size, type: 'have', finishName: r.d.finishName, html: rowHtml(r, familyName) });
  });
  missing.forEach(function(m){
    items.push({ size: m.cat.size, type: 'missing', finishName: m.cat.finishName, html: missingRowHtml(m.cat, m.sku) });
  });

  var counts = {};
  items.forEach(function(it){
    if(!counts[it.size]) counts[it.size] = {have: 0, missing: 0};
    counts[it.size][it.type]++;
  });

  items.sort(function(a, b){
    var sa = parseInt(a.size, 10); if(isNaN(sa)) sa = 0;
    var sb = parseInt(b.size, 10); if(isNaN(sb)) sb = 0;
    if(sa !== sb) return sa - sb;
    if(a.type !== b.type) return a.type === 'have' ? -1 : 1;
    return (a.finishName || '').localeCompare(b.finishName || '');
  });

  var html = '';
  var lastSize;
  var seenFirst = false;
  items.forEach(function(it){
    if(!seenFirst || it.size !== lastSize){
      var c = counts[it.size];
      var label = (it.size ? it.size + ' mm' : 'Sin tamano') + ' (' + c.have + ' tienes' + (c.missing ? ' + ' + c.missing + ' faltan' : '') + ')';
      html += '<tr class="size-group-row"><td colspan="15"><span class="size-bracket">&#9500;&#9472;&#9472; ' + label + ' &#9472;&#9472;&#9508;</span></td></tr>';
      lastSize = it.size;
      seenFirst = true;
    }
    html += it.html;
  });
  return html;
}

function applyLocalFilter(familyName, rows){
  var lf = state.localFilter[familyName];
  if(!lf) return rows;
  return rows.filter(function(r){
    if(lf.color && r.d.finishName !== lf.color) return false;
    if(lf.size && r.d.size !== lf.size) return false;
    return true;
  });
}

